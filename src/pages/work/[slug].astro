---
import { ArrowLeft, ArrowRight } from '@lucide/astro';
import BaseLayout from '../../layouts/BaseLayout.astro';
import { caseStudies, type CaseStudy } from '../../data/caseStudies';

export const prerender = true;

export function getStaticPaths() {
  return caseStudies.map((study) => ({ params: { slug: study.slug }, props: { study } }));
}

interface Props { study: CaseStudy; }
const { study } = Astro.props;
const index = caseStudies.findIndex((item) => item.slug === study.slug);
const next = caseStudies[(index + 1) % caseStudies.length];
---

<BaseLayout title={`${study.title} — Kritika Rastogi`} description={study.summary}>
  <article>
    <header class={`case-hero case-hero--${study.color} band`}>
      <div class="shell">
        <a class="back-link" href="/work"><ArrowLeft size={15} /> All work</a>
        <div class="case-hero__grid">
          <div>
            <p class="kicker">{study.eyebrow} · {study.company}{study.eyebrowSuffix ? ` · ${study.eyebrowSuffix}` : ''}</p>
            {study.companyBio && <p class="case-hero__company-bio">{study.companyBio}</p>}
            <h1>{study.title}</h1>
            <p class="case-hero__summary">{study.summary}</p>
          </div>
          <div class="case-hero__metric">
            <strong>{study.metric}</strong>
            <span>{study.metricLabel}</span>
          </div>
        </div>
        <ul class="tag-list">
          {study.tags.map((tag) => <li class="tag">{tag}</li>)}
        </ul>
        <dl class="case-scope">
          <div><dt>Role</dt><dd>{study.role}</dd></div>
          <div><dt>My ownership</dt><dd>{study.ownership}</dd></div>
        </dl>
      </div>
    </header>

    <section class="setup band">
      <div class="shell setup__grid">
        <div><p class="kicker">THE CHALLENGE</p>{study.challenge.split('\n\n').map(p => <p>{p}</p>)}</div>
        <div><p class="kicker">THE INSIGHT</p>{study.insight.split('\n\n').map(p => <p>{p}</p>)}</div>
      </div>
    </section>

    <section class="approach band">
      <div class="shell">
        <div class="section-title"><p class="kicker">THE APPROACH</p><h2>From evidence to execution.</h2></div>
        <ol>
          {study.approach.map((step) => (
            <li>
              <span>{step.number}</span>
              <h3>{step.title}</h3>
              <p>{step.body}</p>
            </li>
          ))}
        </ol>
      </div>
    </section>

    <section class="artifact band">
      <div class="shell artifact__frame">
        <div class="artifact__chrome"><span></span><span></span><span></span><p>{study.artifact.label}</p></div>
        <div class="artifact__body">
          <div class="artifact__title">
            <p>STRATEGIC ARTIFACT / RECONSTRUCTED</p>
            <h2>{study.artifact.title}</h2>
          </div>
          {study.artifact.image && (
            <div class="artifact__image">
              <img src={study.artifact.image} alt={study.artifact.title} />
            </div>
          )}
          {study.artifact.items.length > 0 && (
            <div class="artifact__items">
              {study.artifact.items.map((item, itemIndex) => (
                <div><span>0{itemIndex + 1}</span><h3>{item.heading}</h3><p>{item.body}</p></div>
              ))}
            </div>
          )}
          {study.artifact.pdf && (
            <div class="artifact__pdf">
              <a href={study.artifact.pdf} target="_blank" rel="noreferrer">{study.artifact.pdfLabel ?? 'See the full framework'} <ArrowRight size={14} /></a>
            </div>
          )}
        </div>
      </div>
    </section>

    <section class="results band">
      <div class="shell">
        <p class="kicker">THE OUTCOME</p>
        <p class="results__statement">{study.outcome}</p>
        <div class="results__metrics">
          {study.secondaryMetrics.map((metric) => <div><strong>{metric.value}</strong><span>{metric.label}</span></div>)}
        </div>
        <p class="measurement-note"><strong>Measurement note:</strong> {study.measurementNote}</p>
      </div>
    </section>

    <section class="reflection band">
      <div class="shell reflection__inner">
        <p class="kicker">WHAT I CARRY FORWARD</p>
        <blockquote>{study.reflection}</blockquote>
      </div>
    </section>

    <a class="next-case" href={`/work/${next.slug}`}>
      <span class="kicker">NEXT CASE · {next.company}</span>
      <strong>{next.shortTitle}</strong>
      <ArrowRight size={34} stroke-width={1.3} />
    </a>
  </article>
</BaseLayout>

<style>
  .case-hero { padding: 30px 0 70px; }
  .case-hero--coral { background: var(--coral); }
  .case-hero--green { background: var(--green); }
  .case-hero--blue { background: var(--blue); color: white; }
  .case-hero--ink { background: var(--ink); color: white; }
  .back-link { display: inline-flex; align-items: center; gap: 8px; margin-bottom: 78px; font-size: 13px; }
  .case-hero__grid { display: grid; grid-template-columns: minmax(0, 1fr) 230px; gap: 70px; align-items: end; }
  .case-hero__company-bio { margin: 14px 0 0; max-width: 620px; font-size: 13px; opacity: 0.7; }
  .case-hero h1 { margin: 24px 0 28px; max-width: 980px; font: 400 71px/0.98 var(--serif); }
  .case-hero__summary { max-width: 750px; margin: 0 0 30px; font-size: 18px; }
  .case-hero__metric { text-align: right; }
  .case-hero__metric strong { display: block; font: 400 82px/0.9 var(--serif); }
  .case-hero__metric span { display: block; margin-top: 13px; font-size: 13px; }
  .case-scope { display: grid; grid-template-columns: 1fr 2fr; gap: 0; margin: 34px 0 0; border-top: 1px solid currentColor; border-bottom: 1px solid currentColor; }
  .case-scope div { padding: 17px 22px 17px 0; }
  .case-scope div + div { padding-left: 22px; border-left: 1px solid currentColor; }
  .case-scope dt { margin-bottom: 6px; font-size: 9px; font-weight: 750; letter-spacing: .12em; text-transform: uppercase; }
  .case-scope dd { margin: 0; font-size: 12px; line-height: 1.45; }
  .setup { padding: 88px 0; }
  .setup__grid { display: grid; grid-template-columns: repeat(2, 1fr); gap: 90px; }
  .setup__grid > div > p:not(.kicker) { margin: 20px 0 0; font: 400 27px/1.28 var(--serif); }
  .approach { padding: 100px 0; background: var(--white); }
  .section-title h2 { margin: 18px 0 56px; font: 400 54px/1 var(--serif); }
  .approach ol { list-style: none; padding: 0; margin: 0; display: grid; grid-template-columns: repeat(auto-fit, minmax(0, 1fr)); border-top: 1px solid var(--line); }
  .approach li { min-height: 320px; padding: 24px; border-right: 1px solid var(--line); }
  .approach li:first-child { border-left: 1px solid var(--line); }
  .approach li > span { color: var(--coral); font-family: var(--serif); }
  .approach h3 { margin: 100px 0 14px; font: 400 29px/1.06 var(--serif); }
  .approach li p { margin: 0; color: var(--muted); }
  .artifact { padding: 100px 0; background: #e8e9e4; }
  .artifact__frame { padding-left: var(--gutter); padding-right: var(--gutter); }
  .artifact__chrome { min-height: 42px; display: flex; align-items: center; gap: 7px; padding: 0 16px; background: #292927; color: white; }
  .artifact__chrome span { width: 8px; height: 8px; border-radius: 50%; background: #777771; }
  .artifact__chrome p { margin: 0 0 0 auto; font-size: 9px; letter-spacing: 0.12em; }
  .artifact__body { background: var(--paper); padding: 58px; box-shadow: 0 30px 60px rgba(23,23,22,0.12); }
  .artifact__title { display: grid; grid-template-columns: 180px 1fr; gap: 40px; }
  .artifact__title p { font-size: 9px; letter-spacing: 0.12em; }
  .artifact__title h2 { margin: 0; max-width: 700px; font: 400 46px/1.05 var(--serif); }
  .artifact__image { margin-top: 48px; }
  .artifact__image img { width: 100%; height: auto; display: block; }
  .artifact__items { margin-top: 64px; display: grid; grid-template-columns: repeat(auto-fit, minmax(0, 1fr)); border-top: 1px solid var(--ink); }
  .artifact__pdf { margin-top: 40px; padding-top: 24px; border-top: 1px solid var(--line); }
  .artifact__pdf a { display: inline-flex; align-items: center; gap: 6px; font-size: 13px; font-weight: 600; color: var(--ink); text-decoration: underline; text-underline-offset: 3px; }
  .artifact__pdf a:hover { color: var(--coral); }
  .artifact__items > div { padding: 22px 22px 0 0; }
  .artifact__items span { color: var(--coral); font: 400 14px/1 var(--serif); }
  .artifact__items h3 { min-height: 60px; margin: 38px 0 14px; font: 400 25px/1.05 var(--serif); }
  .artifact__items p { margin: 0; color: var(--muted); font-size: 13px; }
  .results { padding: 110px 0; }
  .results__statement { max-width: 1080px; margin: 30px 0 68px; font: 400 47px/1.1 var(--serif); }
  .results__metrics { display: grid; grid-template-columns: repeat(3, 1fr); border-top: 1px solid var(--line); }
  .results__metrics div { padding: 24px 0; border-bottom: 1px solid var(--line); }
  .results__metrics strong { display: block; font: 400 42px/1 var(--serif); }
  .results__metrics span { display: block; margin-top: 9px; color: var(--muted); font-size: 12px; }
  .measurement-note { max-width: 760px; margin: 28px 0 0; color: var(--muted); font-size: 13px; }
  .measurement-note strong { color: var(--ink); }
  .reflection { padding: 90px 0; background: var(--green); }
  .reflection__inner { max-width: 1000px; }
  .reflection blockquote { margin: 28px 0 0; font: 400 55px/1.06 var(--serif); }
  .next-case { min-height: 260px; padding: 50px var(--gutter); display: grid; grid-template-columns: 1fr auto; align-items: center; gap: 18px; background: var(--white); }
  .next-case span { grid-column: 1 / -1; }
  .next-case strong { max-width: 900px; font: 400 48px/1.05 var(--serif); }
  @media (max-width: 760px) {
    .case-hero { padding-bottom: 50px; }
    .back-link { margin-bottom: 48px; }
    .case-hero__grid { grid-template-columns: 1fr; gap: 38px; }
    .case-hero h1 { font-size: 49px; }
    .case-hero__metric { text-align: left; }
    .case-scope { grid-template-columns: 1fr; }
    .case-scope div + div { padding-left: 0; border-left: 0; border-top: 1px solid currentColor; }
    .setup__grid, .approach ol, .artifact__items, .results__metrics { grid-template-columns: 1fr; }
    .setup__grid { gap: 50px; }
    .approach li { min-height: 250px; border-left: 1px solid var(--line); border-bottom: 1px solid var(--line); }
    .approach h3 { margin-top: 60px; }
    .artifact { padding: 60px 0; }
    .artifact__body { padding: 30px 22px; }
    .artifact__title { grid-template-columns: 1fr; gap: 16px; }
    .artifact__title h2 { font-size: 36px; }
    .artifact__items { margin-top: 42px; }
    .artifact__items > div { padding: 24px 0; border-bottom: 1px solid var(--line); }
    .artifact__items h3 { min-height: 0; margin-top: 20px; }
    .results__statement { font-size: 36px; }
    .reflection blockquote { font-size: 40px; }
    .next-case strong { font-size: 35px; }
  }
</style>
