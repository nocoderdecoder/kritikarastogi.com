---
import { ArrowUpRight, Download } from '@lucide/astro';
import BaseLayout from '../layouts/BaseLayout.astro';
---

<BaseLayout title="About — Kritika Rastogi" description="Global product marketer with experience across AI, SaaS, advertising platforms, loyalty, and digital ecosystems.">
  <header class="about-hero band">
    <div class="shell about-hero__grid">
      <div>
        <h1>I’ve built product stories in India, Indonesia, Thailand, and Silicon Valley.</h1>
      </div>
      <div class="about-hero__copy">
        <p class="about-intro">What my work taught me.</p>
        <div class="about-belief">
          <p class="about-belief__lead">Products rarely fail because they're bad.</p>
          <p class="about-belief__body">They fail because companies build before they understand the market, customer, and buying decision.</p>
        </div>
        <div class="about-belief">
          <p class="about-belief__lead">Research isn't a phase.</p>
          <p class="about-belief__body">It's how better product decisions, positioning, and go-to-market strategies get made.</p>
        </div>
        <div class="about-belief">
          <p class="about-belief__lead">Positioning isn't messaging.</p>
          <p class="about-belief__body">It's deciding what the product should mean before deciding what to say.</p>
        </div>
        <div class="about-belief">
          <p class="about-belief__lead">Great launches don't depend on heroics.</p>
          <p class="about-belief__body">They depend on repeatable systems that every team can execute and scale.</p>
        </div>
        <div class="about-belief">
          <p class="about-belief__lead">Product Marketing isn't a marketing function.</p>
          <p class="about-belief__body">It's the connective tissue between customers, product, sales, and revenue.</p>
        </div>
        <div class="about-belief">
          <p class="about-belief__lead">AI doesn't change the fundamentals of Product Marketing.</p>
          <p class="about-belief__body">It makes them more important. Customer discovery, positioning, workflow design, and human-centered adoption matter even more when every product sounds the same.</p>
        </div>
      </div>
    </div>
  </header>

  <section class="principles band">
    <div class="shell">
      <p class="kicker">MY SUPERPOWERS</p>
      <div class="principles__grid">
        <div><span>01</span><h2>Strategic Problem Solving</h2><p>I identify customer, product, and market opportunities and translate them into go-to-market strategies, product positioning, and growth initiatives that drive business impact.</p></div>
        <div><span>02</span><h2>Influence Without Authority</h2><p>I lead 10+ cross-functional teams around a shared vision by building trust, creating clarity, and connecting decisions to customer and business outcomes.</p></div>
        <div><span>03</span><h2>Building Scalable Systems</h2><p>I build repeatable frameworks, sales plays, and operating models that enable teams to scale adoption, monetization, and growth long after launch.</p></div>
      </div>
    </div>
  </section>

  <section class="timeline band">
    <div class="shell timeline__grid">
      <div class="timeline__intro"><p class="kicker">THE PATH</p><h2>Built across markets.</h2></div>
      <div class="timeline__list">
        <div><time>2025</time><div><strong>Honda Research Institute</strong><span>AI Product Marketing Manager, Part-Time · San Jose</span></div></div>
        <div><time>2025</time><div><strong>SproutsAI | Agentic AI HR Tech SaaS</strong><span>AI Product Marketing Manager, Part-Time · Palo Alto</span></div></div>
        <div><time>2022–2024</time><div><strong>Burger King</strong><span>Digital Product and Growth Marketing Manager (GTM), Full-Time · Indonesia</span></div></div>
        <div><time>2020–2022</time><div><strong>Gojek | Asia's leading Super App</strong><span>Product and Growth Marketing Manager (GTM), Full-Time · Indonesia</span></div></div>
        <div><time>2018–2020</time><div><strong>Vodafone</strong><span>Strategic Account Executive, Full-Time · India</span></div></div>
        <div><time>2014–2016</time><div><strong>Seven Seas | Real Estate Marketplace</strong><span>Assistant Product and Growth Marketing Manager, Full-Time · Thailand</span></div></div>
      </div>
    </div>
  </section>

  <section class="education band">
    <div class="shell">
      <p class="kicker">EDUCATION</p>
      <div class="education__grid">
        <div><strong>Carnegie Mellon University</strong><span>MS, Product Management & AI · 2025</span><span class="education__location">Pittsburgh, USA</span></div>
        <div><strong>Symbiosis Institute of Business Management</strong><span>MBA · 2018</span><span class="education__location">Pune, India</span></div>
        <div><strong>Lancaster University</strong><span>BA, Business Economics (Honors) · 2014</span><span class="education__location">Lancaster, UK</span></div>
      </div>
    </div>
  </section>
</BaseLayout>

<style>
  .about-hero { padding: 95px 0 110px; }
  .about-hero__grid { display: grid; grid-template-columns: 0.65fr 1.35fr; gap: 60px; max-width: 1500px; width: min(100%, 1500px); margin: 0 auto; padding: 0 var(--gutter) 0 calc(var(--gutter) * 0.4); align-items: start; }
  .about-hero h1 { margin: 25px 0 0; max-width: 620px; font: 400 74px/0.98 var(--serif); }
  .about-intro { font: 400 22px/1.4 var(--serif); margin-bottom: 36px; margin-top: 8px; color: var(--muted); }
  .about-belief { padding: 22px 0; border-top: 1px solid var(--line); }
  .about-belief:last-child { border-bottom: 1px solid var(--line); }
  .about-belief__lead { font: 400 22px/1.2 var(--serif); margin-bottom: 8px; }
  .about-belief__body { font-size: 15px; line-height: 1.6; color: var(--muted); max-width: 620px; }
  .about-actions { display: flex; align-items: center; gap: 28px; margin-top: 36px; }
  .primary-action { display: inline-flex; align-items: center; gap: 9px; padding: 13px 16px; background: var(--ink); color: white; font-size: 13px; }
  .principles { padding: 100px 0; background: var(--green); }
  .principles__grid { display: grid; grid-template-columns: repeat(3, 1fr); margin-top: 50px; border-top: 1px solid var(--ink); }
  .principles__grid > div { padding: 24px 28px 10px 0; }
  .principles__grid span { font-family: var(--serif); }
  .principles__grid h2 { margin: 80px 0 16px; font: 400 35px/1.03 var(--serif); }
  .principles__grid p { margin: 0; max-width: 340px; }
  .timeline { padding: 100px 0; }
  .timeline__grid { display: grid; grid-template-columns: 0.7fr 1.3fr; gap: 90px; }
  .timeline__intro h2 { margin: 18px 0; font: 400 50px/1 var(--serif); }
  .timeline__list > div { display: grid; grid-template-columns: 145px 1fr; gap: 20px; padding: 24px 0; border-top: 1px solid var(--line); }
  .timeline__list > div:last-child { border-bottom: 1px solid var(--line); }
  .timeline time { color: var(--coral); font: 400 22px/1 var(--serif); }
  .timeline strong, .timeline span { display: block; }
  .timeline strong { font: 400 25px/1 var(--serif); }
  .timeline span { margin-top: 7px; color: var(--muted); font-size: 13px; }
  .education { padding: 85px 0; background: var(--white); }
  .education__grid { display: grid; grid-template-columns: repeat(3, 1fr); gap: 35px; margin-top: 40px; }
  .education strong, .education span { display: block; }
  .education strong { font: 400 16px/1.1 var(--serif); }
  .education span { margin-top: 9px; color: var(--muted); font-size: 13px; }
  .education__location { margin-top: 0; color: var(--muted); font-size: 12px; }
  @media (max-width: 760px) {
    .about-hero { padding: 65px 0 75px; }
    .about-hero__grid, .principles__grid, .timeline__grid, .education__grid { grid-template-columns: 1fr; gap: 45px; }
    .about-hero h1 { font-size: 55px; }
    .about-intro { margin-top: 0; }
    .about-actions { align-items: flex-start; flex-wrap: wrap; gap: 20px 24px; }
    .principles__grid > div { border-bottom: 1px solid rgba(23,23,22,.25); padding-bottom: 36px; }
    .principles__grid h2 { margin-top: 40px; }
  }
</style>
