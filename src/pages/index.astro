---
import { ArrowRight, ArrowUpRight } from '@lucide/astro';
import BaseLayout from '../layouts/BaseLayout.astro';
import CaseStudyCard from '../components/CaseStudyCard.astro';
import ArticleRow from '../components/ArticleRow.astro';
import { caseStudies } from '../data/caseStudies';
import { getCollection } from 'astro:content';

const allArticles = (await getCollection('writing', ({ data }) => !data.draft))
  .sort((a, b) => b.data.publishedAt.valueOf() - a.data.publishedAt.valueOf());
const articles = allArticles.slice(0, 3);
---

<BaseLayout>
  <section class="hero band">
    <div class="hero__copy">
      <p class="kicker">PRODUCT MARKETER · AI, SAAS & PLATFORMS · BAY AREA</p>
      <h1>I turn complex products<br />into <em>clear choices.</em></h1>
      <div class="hero__below">
        <div>
          <p class="hero__intro">I'm Kritika. I've launched AI recruiting workflows, grown a loyalty product used by more than one million customers, and taken four advertising products from zero to market.</p>
          <div class="hero__vocabulary" aria-hidden="true">
            <span>Positioning</span>
            <span>Messaging</span>
            <span>Go-to-market</span>
            <span>Buyer insight</span>
            <span>Segmentation</span>
            <span>Launch strategy</span>
            <span>Adoption</span>
            <span>Sales enablement</span>
          </div>
        </div>
        <aside class="hero__reading" aria-label="Latest writing" data-article-ticker>
          <div class="hero__reading-head">
            <span><i></i><span class="kicker">LATEST THINKING</span></span>
            <span class="hero__reading-count" aria-live="polite"><b data-ticker-count>01</b> / {String(allArticles.length).padStart(2, '0')}</span>
            <a href="/writing">View all <ArrowUpRight size={14} /></a>
          </div>
          <div class="hero__reading-window">
            {allArticles.map((article, index) => (
              <a
                class:list={['hero__reading-item', { 'is-active': index === 0 }]}
                href={`/writing/${article.id}`}
                data-ticker-item
                aria-hidden={index === 0 ? 'false' : 'true'}
                tabindex={index === 0 ? 0 : -1}
              >
                <span>{article.data.topic} · {article.data.kind}</span>
                <strong>{article.data.title}</strong>
                <span class="hero__reading-action">Read article <ArrowUpRight size={15} /></span>
              </a>
            ))}
          </div>
        </aside>
      </div>
    </div>
    <div class="hero__stamp" aria-label="Seven plus years, global product marketing">
      <span>7+ YEARS</span>
      <strong>PMM</strong>
      <span>GLOBAL</span>
    </div>
  </section>

  <section class="proof band">
    <div class="shell proof__grid">
      <p class="proof__lead">Seven years of product marketing across <span>AI, super apps, loyalty, and B2B platforms.</span></p>
      <div class="proof__metrics">
        <div><strong>$11M</strong><span>incremental revenue from Gojek launches</span></div>
        <div><strong>1M+</strong><span>users analyzed</span></div>
        <div><strong>6</strong><span>zero-to-one launches</span></div>
        <div><strong>42+</strong><span>customer interviews</span></div>
      </div>
    </div>
  </section>

  <section class="work-section band" id="work">
    <div class="shell">
      <div class="section-head">
        <div>
          <p class="kicker">SELECTED WORK</p>
          <h2>What changed, and what I did.</h2>
        </div>
        <a class="arrow-link" href="/work">All case studies <ArrowUpRight size={16} /></a>
      </div>
      <div class="case-grid">
        {caseStudies.map((study, index) => <CaseStudyCard study={study} index={index} />)}
      </div>
    </div>
  </section>

  <section class="method band">
    <div class="shell method__inner">
      <div class="method__intro">
        <p class="kicker">HOW I THINK</p>
        <h2>Research first. Then a market choice.</h2>
        <p>I start with customer conversations, product behavior, sales evidence, and the alternatives buyers already use. AI helps me search and synthesize; the recommendation remains mine to defend.</p>
      </div>
      <ol class="method__steps">
        <li><span>01</span><div><h3>Understand the current behavior</h3><p>Talk to customers, review sales calls, study usage, and document the workaround the product must replace.</p></div></li>
        <li><span>02</span><div><h3>Choose the audience and promise</h3><p>Define who needs the product most, which alternative it beats, and what evidence supports the claim.</p></div></li>
        <li><span>03</span><div><h3>Equip the whole launch</h3><p>Give product, sales, lifecycle, and content teams one usable narrative and a shared adoption goal.</p></div></li>
        <li><span>04</span><div><h3>Measure what customers do</h3><p>Use adoption, retention, sales feedback, and customer language to decide what changes next.</p></div></li>
      </ol>
    </div>
  </section>

  <section class="writing band">
    <div class="shell">
      <div class="section-head">
        <div>
          <p class="kicker">CURRENT THINKING</p>
          <h2>Notes from the market.</h2>
        </div>
        <a class="arrow-link" href="/writing">Explore writing <ArrowRight size={16} /></a>
      </div>
      <div>
        {articles.map((article) => (
          <ArticleRow
            href={`/writing/${article.id}`}
            title={article.data.title}
            description={article.data.description}
            topic={article.data.topic}
            kind={article.data.kind}
            date={article.data.publishedAt}
            readTime={article.data.readTime}
          />
        ))}
      </div>
    </div>
  </section>

  <section class="manifesto band">
    <div class="shell manifesto__inner">
      <p class="kicker">START A CONVERSATION</p>
      <h2>Building a product customers need to understand quickly?</h2>
      <p>I’m always interested in thoughtful conversations about product, positioning, and go-to-market work.</p>
      <div class="manifesto__actions">
        <a class="arrow-link" href="mailto:kritikarastogi240@gmail.com">Email Kritika <ArrowUpRight size={16} /></a>
        <a class="arrow-link" href="/field-guide">Explore the field guide <ArrowUpRight size={16} /></a>
      </div>
    </div>
  </section>
</BaseLayout>

<script>
  const ticker = document.querySelector<HTMLElement>('[data-article-ticker]');
  const tickerItems = Array.from(ticker?.querySelectorAll<HTMLAnchorElement>('[data-ticker-item]') ?? []);
  const tickerCount = ticker?.querySelector<HTMLElement>('[data-ticker-count]');
  let tickerIndex = 0;
  let tickerTimer: number | undefined;

  const showNextArticle = () => {
    if (tickerItems.length < 2) return;
    const current = tickerItems[tickerIndex];
    tickerIndex = (tickerIndex + 1) % tickerItems.length;
    const next = tickerItems[tickerIndex];

    current.classList.remove('is-active');
    current.classList.add('is-exiting');
    current.setAttribute('aria-hidden', 'true');
    current.tabIndex = -1;

    next.classList.remove('is-exiting');
    next.classList.add('is-active');
    next.setAttribute('aria-hidden', 'false');
    next.tabIndex = 0;
    if (tickerCount) tickerCount.textContent = String(tickerIndex + 1).padStart(2, '0');

    window.setTimeout(() => current.classList.remove('is-exiting'), 550);
  };

  const stopTicker = () => {
    if (tickerTimer) window.clearInterval(tickerTimer);
    tickerTimer = undefined;
  };

  const startTicker = () => {
    stopTicker();
    tickerTimer = window.setInterval(showNextArticle, 3000);
  };

  ticker?.addEventListener('mouseenter', stopTicker);
  ticker?.addEventListener('mouseleave', startTicker);
  ticker?.addEventListener('focusin', stopTicker);
  ticker?.addEventListener('focusout', (event) => {
    if (!ticker.contains(event.relatedTarget as Node | null)) startTicker();
  });
  document.addEventListener('visibilitychange', () => document.hidden ? stopTicker() : startTicker());
  startTicker();
</script>

<style>
  .hero { min-height: min(820px, calc(100svh - 180px)); padding: 34px var(--gutter) 42px; position: relative; overflow: hidden; display: flex; flex-direction: column; }
  .hero__copy { position: relative; z-index: 2; margin-top: clamp(28px, 5vh, 54px); }
  .hero h1 { margin: 22px 0 42px; max-width: 1120px; font: 400 92px/0.98 var(--serif); }
  .hero h1 em { display: inline-block; color: var(--coral); font-weight: 400; transform: translateY(0.06em); }
  .hero__below { width: calc(100% - 220px); display: grid; grid-template-columns: minmax(390px, 1fr) minmax(370px, 470px); gap: clamp(48px, 7vw, 100px); align-items: end; }
  .hero__intro { max-width: 620px; margin: 0; font-size: 18px; line-height: 1.5; }
  .hero__vocabulary { margin-top: 28px; display: flex; flex-wrap: wrap; align-items: baseline; gap: 8px 20px; color: rgba(23, 23, 22, 0.44); }
  .hero__vocabulary span { font-size: 12px; line-height: 1.2; }
  .hero__vocabulary span:nth-child(3n + 1) { font: 400 18px/1.1 var(--serif); }
  .hero__vocabulary span:nth-child(4n) { color: rgba(240, 82, 54, 0.52); }
  .hero__reading { min-width: 0; }
  .hero__reading-head { min-height: 34px; padding: 0 2px 10px; display: grid; grid-template-columns: 1fr auto auto; gap: 18px; align-items: center; }
  .hero__reading-head > span:first-child { display: inline-flex; align-items: center; gap: 9px; }
  .hero__reading-head i { width: 7px; height: 7px; display: block; background: var(--coral); border-radius: 50%; }
  .hero__reading-head a { display: inline-flex; align-items: center; gap: 5px; font-size: 11px; font-weight: 650; }
  .hero__reading-count { color: var(--muted); font-size: 10px; font-variant-numeric: tabular-nums; }
  .hero__reading-count b { color: var(--ink); font-weight: 700; }
  .hero__reading-window { height: 145px; position: relative; overflow: hidden; border-top: 1px solid var(--ink); border-bottom: 1px solid var(--line); }
  .hero__reading-item { position: absolute; inset: 0; padding: 16px 2px 13px; display: grid; grid-template-rows: auto 1fr auto; gap: 6px; opacity: 0; transform: translateX(105%); pointer-events: none; transition: transform 520ms cubic-bezier(.22,.61,.36,1), opacity 320ms ease; }
  .hero__reading-item.is-active { opacity: 1; transform: translateX(0); pointer-events: auto; }
  .hero__reading-item.is-exiting { opacity: 0; transform: translateX(-105%); }
  .hero__reading-item > span:first-child { color: var(--coral); font-size: 9px; letter-spacing: 0.1em; text-transform: uppercase; }
  .hero__reading-item strong { max-width: 430px; font: 400 28px/1.02 var(--serif); }
  .hero__reading-action { display: inline-flex; align-items: center; justify-self: end; gap: 6px; color: var(--muted); font-size: 10px; font-weight: 650; }
  .hero__reading-item:hover strong { color: var(--coral); }
  .hero__stamp { position: absolute; right: var(--gutter); bottom: 36px; width: 154px; height: 154px; border-radius: 50%; background: var(--green); display: flex; flex-direction: column; justify-content: center; align-items: center; transform: rotate(7deg); }
  .hero__stamp strong { font: 400 43px/1 var(--serif); }
  .hero__stamp span { font-size: 9px; letter-spacing: 0.12em; }
  .proof { padding: 84px 0; }
  .proof__grid { display: grid; grid-template-columns: 0.85fr 1.15fr; gap: 80px; align-items: end; }
  .proof__lead { margin: 0; font: 400 43px/1.08 var(--serif); }
  .proof__lead span { color: var(--teal); }
  .proof__metrics { display: grid; grid-template-columns: repeat(2, 1fr); border-top: 1px solid var(--line); border-left: 1px solid var(--line); }
  .proof__metrics div { min-height: 130px; padding: 22px; border-right: 1px solid var(--line); border-bottom: 1px solid var(--line); }
  .proof__metrics strong { display: block; font: 400 38px/1 var(--serif); }
  .proof__metrics span { display: block; margin-top: 9px; color: var(--muted); font-size: 12px; }
  .work-section, .writing { padding: 96px 0; }
  .section-head { display: flex; align-items: end; justify-content: space-between; gap: 30px; margin-bottom: 44px; }
  .section-head h2 { margin: 16px 0 0; font: 400 57px/1 var(--serif); }
  .case-grid { display: grid; grid-template-columns: repeat(2, 1fr); gap: 16px; }
  .method { background: var(--white); padding: 110px 0; }
  .method__inner { display: grid; grid-template-columns: 0.85fr 1.15fr; gap: 100px; }
  .method__intro { position: sticky; top: 120px; align-self: start; }
  .method__intro h2 { margin: 20px 0 24px; font: 400 55px/1.03 var(--serif); }
  .method__intro > p:last-child { max-width: 480px; color: var(--muted); }
  .method__steps { list-style: none; margin: 0; padding: 0; }
  .method__steps li { display: grid; grid-template-columns: 55px 1fr; gap: 18px; padding: 28px 0; border-top: 1px solid var(--line); }
  .method__steps li:last-child { border-bottom: 1px solid var(--line); }
  .method__steps span { color: var(--coral); font: 400 19px/1 var(--serif); }
  .method__steps h3 { margin: 0 0 8px; font: 400 30px/1.05 var(--serif); }
  .method__steps p { margin: 0; max-width: 570px; color: var(--muted); }
  .manifesto { padding: 120px 0; background: var(--green); }
  .manifesto__inner { max-width: 1120px; }
  .manifesto h2 { margin: 26px 0 22px; max-width: 1000px; font: 400 65px/1.03 var(--serif); }
  .manifesto__inner > p:nth-child(3) { max-width: 620px; margin: 0; font-size: 18px; }
  .manifesto__actions { display: flex; flex-wrap: wrap; gap: 30px; margin-top: 38px; }
  @media (max-width: 900px) {
    .hero h1 { font-size: 70px; }
    .hero__stamp { width: 118px; height: 118px; }
    .hero__below { width: calc(100% - 145px); grid-template-columns: 1fr; gap: 28px; }
    .hero__vocabulary { margin-top: 20px; }
    .proof__grid, .method__inner { grid-template-columns: 1fr; gap: 56px; }
    .method__intro { position: static; }
  }
  @media (max-width: 700px) {
    .hero { min-height: calc(100svh - 144px); padding-top: 26px; }
    .hero__copy { margin-top: 24px; }
    .hero h1 { font-size: 53px; margin-top: 16px; }
    .hero__below { width: 100%; gap: 24px; }
    .hero__intro { max-width: 100%; font-size: 16px; }
    .hero__vocabulary { margin-top: 20px; gap: 7px 16px; }
    .hero__vocabulary span { font-size: 12px; }
    .hero__vocabulary span:nth-child(3n + 1) { font-size: 17px; }
    .hero__vocabulary span:nth-child(n + 6) { display: none; }
    .hero__reading-head { grid-template-columns: 1fr auto auto; gap: 12px; }
    .hero__reading-window { height: 142px; }
    .hero__reading-item strong { font-size: 25px; }
    .hero__stamp { display: none; }
    .proof, .work-section, .writing { padding: 70px 0; }
    .proof__lead { font-size: 36px; }
    .case-grid { grid-template-columns: 1fr; }
    .section-head { align-items: flex-start; flex-direction: column; }
    .section-head h2 { font-size: 45px; }
    .method { padding: 76px 0; }
    .method__intro h2 { font-size: 44px; }
    .manifesto { padding: 78px 0; }
    .manifesto h2 { font-size: 42px; }
  }
</style>
