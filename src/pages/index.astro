---
import { ArrowRight, ArrowUpRight, NotebookPen, UserRound } from '@lucide/astro';
import BaseLayout from '../layouts/BaseLayout.astro';
import CaseStudyCard from '../components/CaseStudyCard.astro';
import ArticleRow from '../components/ArticleRow.astro';
import { caseStudies } from '../data/caseStudies';
import { getCollection } from 'astro:content';

const articles = (await getCollection('writing', ({ data }) => !data.draft))
  .sort((a, b) => b.data.publishedAt.valueOf() - a.data.publishedAt.valueOf())
  .slice(0, 3);
---

<BaseLayout>
  <section class="hero band">
    <div class="hero__inner">
      <p class="kicker">AI PRODUCT & GROWTH MARKETER</p>
      <h1>I help companies uncover market opportunities, position products, and <em>build scalable go-to-market strategies that drive adoption and business growth.</em></h1>
      <p class="hero__summary"><span>Hi, I’m Kritika. I’ve worked across AI, SaaS, and marketplaces, solving growth challenges at different stages of a product’s lifecycle.</span> <span>Whether entering new markets, launching 0→1 products, developing category strategy, building monetization motions, or scaling SMB and Enterprise adoption, I enjoy bringing together customer insight, product strategy, and commercial thinking to build repeatable growth systems.</span></p>
      <div class="credibility" aria-label="Education and selected experience">
        <p>TRAINED AT / BUILT AT</p>
        <div class="credibility__item">
          <img class="credibility__logo credibility__logo--cmu" src="/logos/cmu-lettermark.png" alt="Carnegie Mellon University" />
          <span>CMU · MS Product Management</span>
        </div>
        <div class="credibility__item">
          <img class="credibility__logo credibility__logo--hri" src="/logos/honda-main-logo.png" alt="Honda Research Institute" />
          <span>AI Product Marketing Manager</span>
        </div>
        <div class="credibility__item">
          <img class="credibility__logo credibility__logo--square" src="/logos/sproutsai.png" alt="Sprouts AI" />
          <span>AI Product Marketing Manager</span>
        </div>
        <div class="credibility__item">
          <img class="credibility__logo" src="/logos/gojek.svg" alt="Gojek" />
          <span>Product and Growth Marketing Manager</span>
        </div>
        <div class="credibility__item">
          <img class="credibility__logo credibility__logo--square" src="/logos/burger-king.svg" alt="Burger King" />
          <span>Product and Growth Marketing Manager</span>
        </div>
        <div class="credibility__item">
          <img class="credibility__logo" src="/logos/vodafone.svg" alt="Vodafone" />
          <span>Strategic Account Executive</span>
        </div>
      </div>
    </div>
  </section>

  <section class="work-section band" id="work">
    <div class="shell">
      <div class="section-head">
        <div>
          <p class="kicker">SELECTED WORK</p>
          <h2>What changed, and what I did.</h2>
        </div>
        <a class="arrow-link" href="/work">All case studies <ArrowUpRight size={16} /></a>
      </div>
      <div class="case-grid">
        {caseStudies.map((study, index) => <CaseStudyCard study={study} index={index} />)}
      </div>
    </div>
  </section>

  <section class="method band">
    <div class="shell method__inner">
      <div class="method__intro">
        <p class="kicker">WHAT I BRING</p>
        <h2>Research, positioning, and the teams that ship it.</h2>
        <p>I work across the full arc, from finding the right opportunity to equipping teams to execute, so strategy stays connected from insight to launch.</p>
      </div>
      <ol class="method__steps">
        <li><span>01</span><div><h3>Find the right opportunity</h3><p>I combine customer research, product data, and competitive signals to identify where to play, who to target, and which opportunities are worth building a strategy around.</p></div></li>
        <li><span>02</span><div><h3>Turn insight into strategy</h3><p>I translate research into positioning, messaging, and go-to-market recommendations, then bring those insights upstream into roadmap and feature prioritization so strategy shapes what gets built.</p></div></li>
        <li><span>03</span><div><h3>Build systems that scale and enable teams</h3><p>I build GTM playbooks, messaging frameworks, sales plays, battlecards, onboarding kits, and enablement materials that are practical to use and reusable across products, teams, and markets.</p></div></li>
        <li><span>04</span><div><h3>Align early and keep iterating</h3><p>I bring product, sales, marketing, and customer success to a shared vision early in the process, then use adoption data, customer feedback, and sales insights to continuously sharpen what is working.</p></div></li>
      </ol>
    </div>
  </section>

  <section class="writing band">
    <div class="shell">
      <div class="section-head">
        <div>
          <p class="kicker">CURRENT THINKING</p>
          <h2>Notes from the market.</h2>
        </div>
        <a class="arrow-link" href="/writing">Explore writing <ArrowRight size={16} /></a>
      </div>
      <div>
        {articles.map((article) => (
          <ArticleRow
            href={`/writing/${article.id}`}
            title={article.data.title}
            description={article.data.description}
            topic={article.data.topic}
            kind={article.data.kind}
            date={article.data.publishedAt}
            readTime={article.data.readTime}
          />
        ))}
      </div>
    </div>
  </section>

  <section class="manifesto band">
    <div class="shell manifesto__inner">
      <p class="kicker">START A CONVERSATION</p>
      <h2>Building a product customers need to understand quickly?</h2>
      <p>I’m always interested in thoughtful conversations about product, positioning, and go-to-market work.</p>
      <div class="manifesto__actions">
        <a class="arrow-link" href="mailto:kritikarastogi240@gmail.com">Email Kritika <ArrowUpRight size={16} /></a>
        <a class="arrow-link" href="/field-guide">Explore the field guide <ArrowUpRight size={16} /></a>
      </div>
    </div>
  </section>
</BaseLayout>

<style>
  .hero { min-height: min(730px, calc(100svh - 76px)); padding: clamp(54px, 8vh, 88px) var(--gutter) 0; overflow: hidden; display: flex; }
  .hero__inner { width: min(100%, 1500px); margin: 0 auto; display: flex; flex: 1; flex-direction: column; }
  .hero h1 { margin: 22px 0 28px; max-width: 1280px; font: 400 72px/0.97 var(--serif); }
  .hero h1 em { color: var(--coral); font-weight: 400; }
  .hero__summary { max-width: 1100px; margin: 0; font-size: 18px; line-height: 1.55; }
  .hero__actions { display: flex; flex-wrap: wrap; align-items: center; gap: 12px 24px; margin-top: 30px; }
  .hero__primary, .hero__secondary, .hero__tool { min-height: 44px; padding: 0 16px; display: inline-flex; align-items: center; justify-content: center; gap: 8px; font-size: 13px; font-weight: 700; }
  .linkedin-mark { width: 16px; height: 16px; fill: currentColor; flex: 0 0 auto; }
  .hero__primary { background: var(--ink); color: white; }
  .hero__secondary { border: 1px solid var(--ink); }
  .hero__tool { border: 1px solid rgba(240, 82, 54, 0.28); background: rgba(240, 82, 54, 0.08); color: var(--ink); }
  .credibility { margin-top: auto; padding: 24px 0 26px; display: grid; grid-template-columns: 145px repeat(6, minmax(0, 1fr)); align-items: center; gap: 16px; border-bottom: 1px solid var(--ink); }
  .credibility > p { margin: 0; max-width: 90px; color: var(--muted); font-size: 9px; font-weight: 750; line-height: 1.35; letter-spacing: 0.12em; }
  .credibility__item { min-width: 0; display: grid; grid-template-columns: 78px minmax(0, 1fr); align-items: center; gap: 14px; }
  .credibility__logo { width: 72px; height: 34px; object-fit: contain; object-position: left center; filter: grayscale(1); opacity: 0.72; }
  .credibility__logo--cmu { height: 29px; mix-blend-mode: multiply; }
  .credibility__logo--hri { height: 38px; mix-blend-mode: multiply; }
  .credibility__logo--square { width: 42px; height: 42px; }
  .credibility__item span { max-width: 145px; color: var(--muted); font-size: 10px; line-height: 1.35; }
  .work-section { padding: 72px 0 96px; }
  .writing { padding: 96px 0; }
  .section-head { display: flex; align-items: end; justify-content: space-between; gap: 30px; margin-bottom: 44px; }
  .section-head h2 { margin: 16px 0 0; font: 400 57px/1 var(--serif); }
  .case-grid { display: grid; grid-template-columns: repeat(2, 1fr); gap: 16px; }
  .method { background: var(--white); padding: 110px 0; }
  .method__inner { display: grid; grid-template-columns: 0.85fr 1.15fr; gap: 100px; }
  .method__intro { position: sticky; top: 120px; align-self: start; }
  .method__intro h2 { margin: 20px 0 24px; font: 400 55px/1.03 var(--serif); }
  .method__intro > p:last-child { max-width: 480px; color: var(--muted); }
  .method__steps { list-style: none; margin: 0; padding: 0; }
  .method__steps li { display: grid; grid-template-columns: 55px 1fr; gap: 18px; padding: 28px 0; border-top: 1px solid var(--line); }
  .method__steps li:last-child { border-bottom: 1px solid var(--line); }
  .method__steps span { color: var(--coral); font: 400 19px/1 var(--serif); }
  .method__steps h3 { margin: 0 0 8px; font: 400 30px/1.05 var(--serif); }
  .method__steps p { margin: 0; max-width: 570px; color: var(--muted); }
  .manifesto { padding: 120px 0; background: var(--green); }
  .manifesto__inner { max-width: 1120px; }
  .manifesto h2 { margin: 26px 0 22px; max-width: 1000px; font: 400 65px/1.03 var(--serif); }
  .manifesto__inner > p:nth-child(3) { max-width: 620px; margin: 0; font-size: 18px; }
  .manifesto__actions { display: flex; flex-wrap: wrap; gap: 30px; margin-top: 38px; }
  @media (min-width: 901px) and (max-width: 1300px) {
    .hero { padding-top: 48px; }
    .hero h1 { margin: 18px 0 22px; font-size: 70px; }
    .hero__summary { font-size: 17px; }
    .hero__actions { margin-top: 24px; }
    .credibility { padding: 16px 0; }
  }
  @media (max-width: 900px) {
    .hero h1 { font-size: 66px; }
    .credibility { grid-template-columns: repeat(2, minmax(0, 1fr)); }
    .credibility > p { grid-column: 1 / -1; max-width: none; }
    .method__inner { grid-template-columns: 1fr; gap: 56px; }
    .method__intro { position: static; }
  }
  @media (max-width: 700px) {
    .hero { min-height: 0; padding-top: 34px; }
    .hero h1 { margin: 15px 0 20px; font-size: 43px; line-height: 1; }
    .hero__summary { font-size: 16px; }
    .hero__summary span:last-child { display: none; }
    .hero__actions { margin-top: 22px; display: grid; grid-template-columns: repeat(3, minmax(0, 1fr)); gap: 6px; }
    .hero__primary, .hero__secondary, .hero__tool { min-width: 0; min-height: 42px; padding: 0 7px; gap: 5px; font-size: 11px; white-space: nowrap; }
    .credibility { margin-top: 30px; padding: 18px 0 20px; gap: 16px 10px; border-top: 1px solid var(--line); }
    .credibility__item { grid-template-columns: 58px minmax(0, 1fr); gap: 9px; }
    .credibility__logo { width: 54px; height: 26px; }
    .credibility__logo--square { width: 34px; height: 34px; }
    .credibility__item span { font-size: 9px; }
    .work-section, .writing { padding: 70px 0; }
    .case-grid { grid-template-columns: 1fr; }
    .section-head { align-items: flex-start; flex-direction: column; }
    .section-head h2 { font-size: 45px; }
    .method { padding: 76px 0; }
    .method__intro h2 { font-size: 44px; }
    .manifesto { padding: 78px 0; }
    .manifesto h2 { font-size: 42px; }
  }
</style>
