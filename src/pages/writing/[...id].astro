---
import { ArrowLeft, ArrowUpRight } from '@lucide/astro';
import BaseLayout from '../../layouts/BaseLayout.astro';
import { getCollection, render } from 'astro:content';

export async function getStaticPaths() {
  const entries = await getCollection('writing', ({ data }) => !data.draft);
  return entries.map((entry) => ({ params: { id: entry.id }, props: { entry } }));
}

const { entry } = Astro.props;
const { Content } = await render(entry);
---

<BaseLayout title={`${entry.data.title} — Kritika Rastogi`} description={entry.data.description}>
  <article>
    <header class="article-head band">
      <div class="article-shell">
        <a class="back" href="/writing"><ArrowLeft size={15} /> All writing</a>
        <div class="article-meta"><span class="kicker">{entry.data.topic} · {entry.data.kind}</span><time>{entry.data.publishedAt.toLocaleDateString('en-US', { month: 'long', day: 'numeric', year: 'numeric', timeZone: 'UTC' })}</time></div>
        <h1>{entry.data.title}</h1>
        <p class="dek">{entry.data.description}</p>
        <div class="article-detail"><span>{entry.data.readTime} read</span><span>By Kritika Rastogi</span></div>
      </div>
    </header>
    <div class="article-shell article-content">
      <Content />
      {entry.data.sourceUrl && (
        <aside class="source-note">
          <p class="kicker">ORIGINALLY PUBLISHED ON {entry.data.sourceLabel ?? 'THE WEB'}</p>
          <a href={entry.data.sourceUrl} target="_blank" rel="noreferrer">Read the original <ArrowUpRight size={16} /></a>
        </aside>
      )}
    </div>
  </article>
</BaseLayout>

<style>
  .article-shell { width: min(100% - 40px, 820px); margin-left: auto; margin-right: auto; }
  .article-head { padding: 38px 0 72px; }
  .back { display: inline-flex; align-items: center; gap: 8px; margin-bottom: 70px; font-size: 13px; }
  .article-meta, .article-detail { display: flex; justify-content: space-between; gap: 20px; color: var(--muted); font-size: 12px; }
  .article-meta .kicker { color: var(--coral); }
  .article-head h1 { margin: 30px 0 26px; font: 400 61px/1 var(--serif); }
  .dek { margin: 0 0 42px; color: var(--muted); font-size: 20px; line-height: 1.5; }
  .article-detail { padding-top: 17px; border-top: 1px solid var(--line); }
  .article-content { padding-top: 70px; padding-bottom: 110px; font-size: 18px; line-height: 1.75; }
  .article-content :global(h2) { margin: 60px 0 18px; font: 400 38px/1.1 var(--serif); }
  .article-content :global(h3) { margin: 38px 0 12px; font: 400 26px/1.15 var(--serif); }
  .article-content :global(p) { margin: 0 0 24px; }
  .article-content :global(blockquote) { margin: 45px 0; padding: 25px 0 25px 28px; border-left: 3px solid var(--coral); font: 400 29px/1.3 var(--serif); }
  .article-content :global(ul), .article-content :global(ol) { padding-left: 24px; }
  .article-content :global(li) { margin-bottom: 10px; }
  .article-content :global(a) { border-bottom: 1px solid var(--coral); }
  .source-note { margin-top: 70px; padding: 25px; background: var(--green); }
  .source-note a { display: inline-flex; align-items: center; gap: 8px; margin-top: 30px; border-bottom: 1px solid var(--ink); font-size: 13px; }
  @media (max-width: 650px) {
    .article-head h1 { font-size: 44px; }
    .back { margin-bottom: 50px; }
    .article-content { font-size: 17px; }
  }
</style>
