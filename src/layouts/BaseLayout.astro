---
import { ArrowUpRight, Menu, X } from '@lucide/astro';
import Analytics from '@vercel/analytics/astro';
import '../styles/global.css';

interface Props {
  title?: string;
  description?: string;
  image?: string;
}

const {
  title = 'Kritika Rastogi — AI Product Marketer',
  description = 'Product marketer turning customer truth into positioning, launches, and adoption across AI, SaaS, and digital products.',
  image = '/og-image.png'
} = Astro.props;
const canonical = new URL(Astro.url.pathname, Astro.site);
const pathname = Astro.url.pathname;
const personSchema = {
  '@context': 'https://schema.org',
  '@type': 'Person',
  name: 'Kritika Rastogi',
  url: 'https://kritikarastogi.com',
  jobTitle: 'Product Marketing Manager',
  sameAs: [
    'https://www.linkedin.com/in/kritikarastogi240',
    'https://medium.com/@kritikarastogi240'
  ],
  address: {
    '@type': 'PostalAddress',
    addressLocality: 'Sunnyvale',
    addressRegion: 'CA',
    addressCountry: 'US'
  }
};
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width" />
    <meta name="description" content={description} />
    <meta name="theme-color" content="#f7f7f4" />
    <link rel="canonical" href={canonical} />
    <link rel="icon" href="/favicon.svg" type="image/svg+xml" />
    <meta property="og:type" content="website" />
    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:image" content={new URL(image, Astro.site)} />
    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:title" content={title} />
    <meta name="twitter:description" content={description} />
    <meta name="twitter:image" content={new URL(image, Astro.site)} />
    <script is:inline type="application/ld+json" set:html={JSON.stringify(personSchema)}></script>
    <title>{title}</title>
  </head>
  <body>
    <a class="skip-link" href="#main">Skip to content</a>
    <header class="site-header" data-header>
      <a class="wordmark" href="/" aria-label="Kritika Rastogi home">
        <span>KR</span>
        <strong>Kritika Rastogi</strong>
      </a>
      <button class="menu-button" type="button" aria-label="Open menu" aria-expanded="false" data-menu-button>
        <Menu class="menu-open" size={21} stroke-width={1.8} />
        <X class="menu-close" size={21} stroke-width={1.8} />
      </button>
      <nav class="site-nav" aria-label="Primary navigation" data-nav>
        <a href="/work" aria-current={pathname.startsWith('/work') ? 'page' : undefined}>Work</a>
        <a href="/writing" aria-current={pathname.startsWith('/writing') ? 'page' : undefined}>Writing</a>
        <a href="/field-guide" aria-current={pathname.startsWith('/field-guide') ? 'page' : undefined}>Field guide</a>
        <a href="/about" aria-current={pathname.startsWith('/about') ? 'page' : undefined}>About</a>
        <a class="nav-cta" href="https://www.linkedin.com/in/kritikarastogi240" target="_blank" rel="noreferrer">
          LinkedIn <ArrowUpRight size={15} stroke-width={1.8} />
        </a>
      </nav>
    </header>
    <main id="main"><slot /></main>
    <footer class="site-footer">
      <div class="footer-lead">
        <p class="kicker">LET'S MAKE THE COMPLEX LAND</p>
        <h2>Have a product that deserves a clearer story?</h2>
      </div>
      <div class="footer-links">
        <a href="mailto:kritikarastogi240@gmail.com">kritikarastogi240@gmail.com</a>
        <a href="tel:+12244201991">+1 224 420 1991</a>
        <a href="/Kritika-Rastogi-Resume.pdf">Resume</a>
        <a href="https://medium.com/@kritikarastogi240" target="_blank" rel="noreferrer">Medium</a>
      </div>
      <div class="footer-meta">
        <span>Sunnyvale, California</span>
        <span>© {new Date().getFullYear()} Kritika Rastogi</span>
      </div>
    </footer>
    <script>
      const button = document.querySelector<HTMLButtonElement>('[data-menu-button]');
      const nav = document.querySelector<HTMLElement>('[data-nav]');
      button?.addEventListener('click', () => {
        const open = button.getAttribute('aria-expanded') === 'true';
        button.setAttribute('aria-expanded', String(!open));
        button.setAttribute('aria-label', open ? 'Open menu' : 'Close menu');
        nav?.classList.toggle('is-open', !open);
        document.body.classList.toggle('menu-is-open', !open);
      });
      nav?.querySelectorAll('a').forEach((link) => link.addEventListener('click', () => {
        button?.setAttribute('aria-expanded', 'false');
        button?.setAttribute('aria-label', 'Open menu');
        nav.classList.remove('is-open');
        document.body.classList.remove('menu-is-open');
      }));
      document.addEventListener('keydown', (event) => {
        if (event.key !== 'Escape' || button?.getAttribute('aria-expanded') !== 'true') return;
        button.setAttribute('aria-expanded', 'false');
        button.setAttribute('aria-label', 'Open menu');
        nav?.classList.remove('is-open');
        document.body.classList.remove('menu-is-open');
        button.focus();
      });
    </script>
    <Analytics />
  </body>
</html>
